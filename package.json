{
  "name": "s4-data-api",
  "version": "1.0.0",
  "description": "Cross-border e-commerce data API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:init": "psql -h $DB_HOST -U $DB_USER -d $DB_NAME -f src/db/schema.sql"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.1.0",
    "@fastify/rate-limit": "^10.2.1",
    "pg": "^8.13.1",
    "ioredis": "^5.4.2",
    "cheerio": "^1.0.0",
    "node-fetch": "^3.3.2",
    "uuid": "^11.1.0",
    "https-proxy-agent": "^7.0.6"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0"
  }
}
